ta.status == 200) {\r\n            alert('تم الاشتراك بنجاح ')\r\n          }\r\n          else {\r\n            alert('حقل البريد الإلكتروني مستخدم من قبل')\r\n          }\r\n        })\r\n    }\r\n  }\r\n\r\n  return (\r\n    <>\r\n      <div className='page-title'>\r\n        <h1>{texts.associationRegister}</h1>\r\n      </div>\r\n      <div className='content'>\r\n\r\n        <div className='row justify-content-center'>\r\n          <div className='row px-3 py-5 d-flex gap-3 col-md-6 '>\r\n            <button className='col btn bg-dark text-white' onClick={() => setMemberShip('single')}>عضوية فردية</button>\r\n            <button className='col btn bg-dark text-white' onClick={() => setMemberShip('multiple')}>عضوية جهات</button>\r\n          </div>\r\n        </div>\r\n        {/* single  */}\r\n        {memberShip == 'single' && (\r\n\r\n          <div className='row justify-content-center text-end'>\r\n            <div className='col-md-6'>\r\n              <div className='card shadow-sm'>\r\n                <div className='card-header'>\r\n                  <h4 className='text-black'>إنشاء عضوية افراد</h4>\r\n                </div>\r\n                <div className='card-body'>\r\n                  <input name='name' className='form-control my-4' placeholder='الاسم (رباعي)' defaultValue={individual.name} onChange={e => setIndividual({ ...individual, name: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='العمر' defaultValue={individual.age} onChange={e => setIndividual({ ...individual, age: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='الجنسية' defaultValue={individual.nationality} onChange={e => setIndividual({ ...individual, nationality: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='رقم الهوية' defaultValue={individual.identityNo} onChange={e => setIndividual({ ...individual, identityNo: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='مصدر الهوية' defaultValue={individual.identitySource} onChange={e => setIndividual({ ...individual, identitySource: e.target.value })} />\r\n                  <label>تاريخ اصدار الهوية</label>\r\n                  <input type='date' className='form-control text-secondary' defaultValue={individual.identityDate} onChange={e => setIndividual({ ...individual, identityDate: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='مكان الميلاد' defaultValue={individual.birthPlace} onChange={e => setIndividual({ ...individual, birthPlace: e.target.value })} />\r\n                  <label>تاريخ الميلاد</label>\r\n                  <input type='date' className='form-control text-secondary' defaultValue={individual.birthDate} onChange={e => setIndividual({ ...individual, birthDate: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='مكان الاقامة' defaultValue={individual.residence} onChange={e => setIndividual({ ...individual, residence: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='المهنة' defaultValue={individual.occupation} onChange={e => setIndividual({ ...individual, occupation: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='رقم الجوال' defaultValue={individual.phone} onChange={e => setIndividual({ ...individual, phone: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='رقم الهاتف' defaultValue={individual.tel} onChange={e => setIndividual({ ...individual, tel: e.target.value })} />\r\n                  <label>البريد الإلكتروني</label>\r\n                  <input name='name' className='form-control my-4' placeholder='البريد الإلكتروني' defaultValue={individual.email} onChange={e => setIndividual({ ...individual, email: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='صندوق البريد' defaultValue={individual.Postalbox} onChange={e => setIndividual({ ...individual, Postalbox: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='الرمز البريدي' defaultValue={individual.Postalcode} onChange={e => setIndividual({ ...individual, Postalcode: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='المؤهل العلمي' defaultValue={individual.qualification} onChange={e => setIndividual({ ...individual, qualification: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='التخصص' defaultValue={individual.specialization} onChange={e => setIndividual({ ...individual, specialization: e.target.value })} />\r\n                  <select className='form-control my-4 text-secondary' defaultValue={individual.role} onChange={e => setIndividual({ ...individual, role: e.target.value })}>\r\n                    <option hidden>ارغب الإنضمام لعضوية الجمعية</option>\r\n                    <option value='employee'>عامل</option>\r\n                    <option value='affiliated'>منتسب</option>\r\n                  </select>\r\n                  <textarea className='form-control my-4' placeholder='وذلك لكوني' defaultValue={individual.reason} onChange={e => setIndividual({ ...individual, reason: e.target.value })}></textarea>\r\n\r\n                  <a href={IndividualMembershopApprovalPDF} className='decoration-none' download>\r\n                    <div className='download-approval'>\r\n                      <li className=\"fa-sharp fa-solid fa-download\"></li>\r\n                      <label>تحميل صيغة خطاب إقرار الجمعية</label>\r\n                    </div>\r\n                  </a>\r\n\r\n                  <label className='d-block'>الرجاء ارفاق إقرار الجمعية بعد تعبئته</label>\r\n                  <input className='pt-3 pb-5' type='file' onChange={e => setEndorsement(e.target.files[0])} />\r\n\r\n                  <label className='d-block'>إرفاق  صورة الهوية</label>\r\n                  <input className='pt-3 pb-5' type='file' onChange={e => setIdentityImg(e.target.files[0])} />\r\n\r\n                  <label className='d-block'>إرفاق صورة العنوان الوطني</label>\r\n                  <input className='pt-3 pb-5' type='file' onChange={e => setNationalAddressImg(e.target.files[0])} />\r\n\r\n                  <label className='d-block'>إرفاق صورة حوالة سداد الرسوم</label>\r\n                  <input className='pt-3 pb-5' type='file' onChange={e => setTransferImg(e.target.files[0])} />\r\n\r\n                  <a href={accountPDF} className='decoration-none' download>\r\n                    <div className='download-approval'>\r\n                      <li className=\"fa-sharp fa-solid fa-download\"></li>\r\n                      <label>تحميل بيانات الحساب و قيمة الرسوم</label>\r\n                    </div>\r\n                  </a>\r\n\r\n                  {errors.length != 0 && <label className='mt-5 d-block text-danger'>الرجاء تعبئة الحقول التالية: <br />{errors.map(e => ` ${e},`)}</label>}\r\n\r\n                  <button onClick={submit} className='btn btn bg-dark text-white float-start mt-5'>التسجيل</button>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        )}\r\n\r\n        {memberShip == 'multiple' && (\r\n\r\n          <div className='row justify-content-center text-end'>\r\n            <div className='col-md-6'>\r\n\r\n\r\n              <div className='card shadow-sm mb-5'>\r\n                <div className='card-header'>\r\n                  <h4 className='text-black'>بيانات االجهة</h4>\r\n                </div>\r\n                <div className='card-body'>\r\n                  <input name='name' className='form-control my-4' placeholder='اسم الجهة' defaultValue={facility.facilityName} onChange={e => setFacility({ ...facility, facilityName: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='الجنسية / المقر' defaultValue={facility.facilityPlace} onChange={e => setFacility({ ...facility, facilityPlace: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='رقم التسجيل / الترخيص' defaultValue={facility.facilityRegisterNo} onChange={e => setFacility({ ...facility, facilityRegisterNo: e.target.value })} />\r\n                  <label>تاريخ الإصدار</label>\r\n                  <input type='date' className='form-control text-secondary' defaultValue={facility.facilityIssueDate} onChange={e => setFacility({ ...facility, facilityIssueDate: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='رقم الجوال' defaultValue={facility.facilityPhone} onChange={e => setFacility({ ...facility, facilityPhone: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='رقم الهاتف' defaultValue={facility.facilityTel} onChange={e => setFacility({ ...facility, facilityTel: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='البريد الإلكتروني' defaultValue={facility.facilityEmail} onChange={e => setFacility({ ...facility, facilityEmail: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='صندوق البريد' defaultValue={facility.facilityPostalBox} onChange={e => setFacility({ ...facility, facilityPostalBox: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='الرمز البريدي' defaultValue={facility.facilityPostalCode} onChange={e => setFacility({ ...facility, facilityPostalCode: e.target.value })} />\r\n                  <select className='form-control my-4 text-secondary' defaultValue={facility.facilityRole} onChange={e => setFacility({ ...facility, facilityRole: e.target.value })}>\r\n                    <option hidden>نوع العضوية</option>\r\n                    <option value='employee'>عامل</option>\r\n                    <option value='affiliated'>منتسب</option>\r\n                  </select>\r\n                  <textarea className='form-control my-4' placeholder='الهدف من العضوية' defaultValue={facility.facilityGoal} onChange={e => setFacility({ ...facility, facilityGoal: e.target.value })}></textarea>\r\n                </div>\r\n              </div>\r\n\r\n\r\n              <div className='card shadow-sm'>\r\n                <div className='card-header'>\r\n                  <h4 className='text-black'>بيانات ممثل الجهة</h4>\r\n                </div>\r\n                <div className='card-body'>\r\n                  <input name='name' className='form-control my-4' placeholder='الاسم (رباعي)' defaultValue={facility.name} onChange={e => setFacility({ ...facility, name: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='العمر' defaultValue={facility.age} onChange={e => setFacility({ ...facility, age: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='الجنسية' defaultValue={facility.nationality} onChange={e => setFacility({ ...facility, nationality: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='رقم الهوية' defaultValue={facility.identityNo} onChange={e => setFacility({ ...facility, identityNo: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='مصدر الهوية' defaultValue={facility.identitySource} onChange={e => setFacility({ ...facility, identitySource: e.target.value })} />\r\n                  <label>تاريخ اصدار الهوية</label>\r\n                  <input type='date' className='form-control text-secondary' defaultValue={facility.identityDate} onChange={e => setFacility({ ...facility, identityDate: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='مكان الميلاد' defaultValue={facility.birthPlace} onChange={e => setFacility({ ...facility, birthPlace: e.target.value })} />\r\n                  <label>تاريخ الميلاد</label>\r\n                  <input type='date' className='form-control text-secondary' defaultValue={facility.birthDate} onChange={e => setFacility({ ...facility, birthDate: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='مكان الاقامة' defaultValue={facility.residence} onChange={e => setFacility({ ...facility, residence: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='المهنة' defaultValue={facility.occupation} onChange={e => setFacility({ ...facility, occupation: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='رقم الجوال' defaultValue={facility.phone} onChange={e => setFacility({ ...facility, phone: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='رقم الهاتف' defaultValue={facility.tel} onChange={e => setFacility({ ...facility, tel: e.target.value })} />\r\n                  <label>البريد الإلكتروني</label>\r\n                  <input name='name' className='form-control my-4' placeholder='البريد الإلكتروني' defaultValue={facility.email} onChange={e => setFacility({ ...facility, email: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='صندوق البريد' defaultValue={facility.Postalbox} onChange={e => setFacility({ ...facility, Postalbox: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='الرمز البريدي' defaultValue={facility.Postalcode} onChange={e => setFacility({ ...facility, Postalcode: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='المؤهل العلمي' defaultValue={facility.qualification} onChange={e => setFacility({ ...facility, qualification: e.target.value })} />\r\n                  <input name='name' className='form-control my-4' placeholder='التخصص' defaultValue={facility.specialization} onChange={e => setFacility({ ...facility, specialization: e.target.value })} />\r\n                  <select className='form-control my-4 text-secondary' defaultValue={facility.role} onChange={e => setFacility({ ...facility, role: e.target.value })}>\r\n                    <option hidden>ارغب الإنضمام لعضوية الجمعية</option>\r\n                    <option value='employee'>عامل</option>\r\n                    <option value='affiliated'>منتسب</option>\r\n                  </select>\r\n                  <textarea className='form-control my-4' placeholder='وذلك لكوني' defaultValue={facility.reason} onChange={e => setFacility({ ...facility, reason: e.target.value })}></textarea>\r\n\r\n                  <a href={EntitiesMembershopApprovalPDF} className='decoration-none' download>\r\n                    <div className='download-approval'>\r\n                      <li className=\"fa-sharp fa-solid fa-download\"></li>\r\n                      <label>تحميل صيغة خطاب إقرار الجمعية</label>\r\n                    </div>\r\n                  </a>\r\n\r\n                  <label className='d-block'>الرجاء ارفاق إقرار الجمعية بعد تعبئته</label>\r\n                  <input className='pt-3 pb-5' type='file' onChange={e => setFacilityEndorsement(e.target.files[0])} />\r\n\r\n                  <label className='d-block'>إرفاق  صورة الهوية</label>\r\n                  <input className='pt-3 pb-5' type='file' onChange={e => setFacilityIdentityImg(e.target.files[0])} />\r\n\r\n                  <label className='d-block'>إرفاق صورة السجل</label>\r\n                  <input className='pt-3 pb-5' type='file' onChange={e => setFacilityRegisterImg(e.target.files[0])} />\r\n\r\n                  <label className='d-block'>إرفاق صورة العنوان الوطني</label>\r\n                  <input className='pt-3 pb-5' type='file' onChange={e => setFacilityNationalAddressImg(e.target.files[0])} />\r\n\r\n                  <label className='d-block'>إرفاق صورة حوالة سداد الرسوم</label>\r\n                  <input className='pt-3 pb-5' type='file' onChange={e => setFacilityTransferImg(e.target.files[0])} />\r\n\r\n                  <a href={accountPDF} className='decoration-none' download>\r\n                    <div className='download-approval'>\r\n                      <li className=\"fa-sharp fa-solid fa-download\"></li>\r\n                      <label>تحميل بيانات الحساب و قيمة الرسوم</label>\r\n                    </div>\r\n                  </a>\r\n\r\n                  {facilityErrors.length != 0 && <label className='mt-5 d-block text-danger'>الرجاء تعبئة الحقول التالية: <br />{facilityErrors.map(e => ` ${e},`)}</label>}\r\n\r\n                  <button onClick={submitFacility} className='btn btn bg-dark text-white float-start mt-5'>التسجيل</button>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        )}\r\n\r\n        <div className='row justify-content-center text-end'>\r\n          <div className='col-md-6'>\r\n            <button onClick={() => navigate('/subscribers') } className='btn btn bg-dark text-white my-5'>عرض المشتركين</button>\r\n          </div>\r\n        </div>\r\n\r\n      </div>\r\n    </>\r\n  )\r\n}","C:\\Users\\D2105\\Documents\\Projects\\Front-end\\React\\association\\src\\pages\\AwarenessCornerRequest.js",["343"],[],"import React, { useContext } from 'react'\r\nimport Texts from '../Texts';\r\nimport { Context } from '../Context';\r\n\r\nexport default function AwarenessCornerRequest() {\r\n\r\n  const { lang } = useContext(Context);\r\n  const texts = Texts[lang];\r\n\r\n  return (\r\n    <>\r\n      <div className='page-title'>\r\n        <h1>{texts.awarenessCornerRequest}</h1>\r\n      </div>\r\n      <div className='content' style={{paddingInline: '300px'}}>\r\n        <h4>وصف الخدمة:</h4>\r\n        <p>تتيح هذه الخدمة طلب تنفيذ ركن توعوي للتثقيف والتوعية في مجال العنف والايذاء والتشرد. </p>\r\n        <br/>\r\n        <h4>الفئة المستهدفة:</h4>\r\n        <p>جهات حكومية وغير حكومية، شركات.</p>\r\n        <br/>\r\n        <h4>متطلبات الحصول على الخدمة:</h4>\r\n        <p>\r\n          <ul style={{paddingInline: '40px'}}>\r\n            <li>ان يكون للجهة سجل تجاري</li>\r\n            <li>خطاب من رئيس الجهة او صاحب الصلاحية بالموافقة على إقامة ركن توعوي.</li>\r\n            <li>تحديد المدينة المكان،والتاريخ لاقامة الركن التوعوي مع ارفاق حجز للمكان او القاعة في حال كان خارج المؤسسة.</li>\r\n            <li>تحديد الفئة المستهدفة.</li>\r\n            <li>تحديد عدد الزوار.</li>\r\n            <li>يجب تقديم الطلب قبل شهر من تاريخ إقامة الفعالية.</li>\r\n          </ul>\r\n        </p>\r\n        <br/>\r\n        <h4>إجراءات الحصول على الخدمة:</h4>\r\n        <p>\r\n          <ul style={{paddingInline: '40px'}}>\r\n            <li>تقديم الطلب عبر الموقع الالكتروني او عن طريق ارفاق الخطاب في البريد الالكتروني.</li>\r\n            <li>التواصل مع مقدم الطلب لاكمال إجراءات الطلب.</li>\r\n          </ul>\r\n        </p>\r\n        <br/>\r\n        <h4>معلومات التواصل:</h4>\r\n        <p>البريد الالكتروني: <a href='mailto: info@vahpa.org.sa' target='_blank'>info@vahpa.org.sa</a></p>\r\n\r\n      </div>\r\n    </>\r\n  )\r\n}","C:\\Users\\D2105\\Documents\\Projects\\Front-end\\React\\association\\src\\pages\\AboutMembership.js",["344","345","346","347"],[],"import React, { useContext } from 'react'\r\nimport Texts from '../Texts';\r\nimport { Context } from '../Context';\r\n\r\nexport default function AboutMembership() {\r\n\r\n  const { lang } = useContext(Context);\r\n  const texts = Texts[lang];\r\n\r\n  return (\r\n    <>\r\n      <div className='page-title'>\r\n        <h1>{texts.aboutMembership}</h1>\r\n      </div>\r\n      <div className='content' style={{ paddingInline: '300px' }}>\r\n        <h4>أنواع العضوية</h4>\r\n        <p>\r\n          <ul style={{ padding: '40px' }}>\r\n            <li>\r\n              <h4>عضو عامل:</h4>\r\n              <p>هو العضو الذي اشترك في تأسيس الجمعية، أو التحق بها بعد قيامها وقبل مجلس الإدارة عضويته، وكان من المتخصصين أو المهتمين أو الممارسين لتخصص الجمعية، ويحق للعضو حضور اجتماعات الجمعية العمومية والتصويت على قراراتها، ‌والترشح لعضوية مجلس الإدارة، وذلك بعد مدةً لا تقل عن ستة أشهر من تاريخ التحاقه بالجمعية</p>\r\n              <br />\r\n            </li>\r\n            <li>\r\n              <h4>عضو شرفي:</h4>\r\n              <p>يكون عضوًا شرفيًا في الجمعية من ترى الجمعية العمومية منحه عضوية شرفية بمجلس الإدارة نظير تميزه في مجال عمل الجمعية.</p>\r\n              <br />\r\n            </li>\r\n            <li>\r\n              <h4>عضو فخري:</h4>\r\n              <p>يكون عضوًا فخريًا في الجمعية من ترى الجمعية العمومية منحه عضوية فخرية فيها نظير مساهمته المادية أو المعنوية للجمعية.</p>\r\n              <br />\r\n            </li>\r\n            <li>\r\n              <h4>عضو منتسب:</h4>\r\n              <p>يكون العضو منتسبًا في الجمعية إذا تقدم بطلب عضوية عامل للجمعية وظهر عدم انطباق أحد شروط العضوية العاملة عليه وصدر قرار من مجلس الإدارة بقبوله عضواً منتسباً، ويحق للعضو الاطلاع على مستندات الجمعية والاشتراك في أنشطتها أو تقدم بطلب العضوية منتسبًا ولا يحق للعضو حضور اجتماعات الجمعية العمومية ولا الترشح لعضوية مجلس الإدارة.</p>\r\n              <br />\r\n            </li>\r\n          </ul>\r\n        </p>\r\n        <br />\r\n\r\n        <h4>شروط العضوية:</h4>\r\n        <p>\r\n          <ul style={{ padding: '40px' }}>\r\n            <li>‌أن يكون سعودي الجنسية.</li>\r\n            <li>‌ألا يقل عمره عن ثمانية عشر عاما.</li>\r\n            <li>‌ان يكون كامل الأھلیة المعتبرة شرعا.</li>\r\n            <li>‌ان لا يكون قد صدر بحقة حكم نھائي بإدانته في جريمة مخلة بالشرف او بالأمانة مالم يكن قد رد إليه اعتباره</li>\r\n            <li>‌ان يكون قد سدد الحد الأدنى من الاشتراك السنوي</li>\r\n            <li>‌التعاون مع الجمعية ومنسوبيها لتحقيق أهدافها.</li>\r\n            <li>‌عدم القيام بأي أمر من شأنه أن يلحق ضرراً بالجمعية.</li>\r\n            <li>‌الالتزام بقرارات الجمعية العمومية.</li>\r\n          </ul>\r\n        </p>\r\n        <br />\r\n\r\n        <h4>فقدان العضوية</h4>\r\n        <p>يفقد العضو عضويته في الحالات التالية:\r\n          <ul style={{ paddingInline: '40px' }}>\r\n            <li>الانسحاب من الجمعية بطلب كتابي.</li>\r\n            <li>الوفاة.</li>\r\n            <li>إذا فقد شرطاً من شروط العضوية.</li>\r\n            <li>إذا صدر قرار من الجمعية العمومية بسحب العضوية في الحالات الآتية:</li>\r\n            <li>إذا أقدم العضو على تصرف من شأنه أن يلحق ضرراً مادياً أو أدبياً بالجمعية.</li>\r\n            <li>إذا أقدم العضو باستغلال عضويته في الجمعية لغرض شخصي</li>\r\n            <li>إذا تأخر العضو عن أداء الاشتراك عن موعد استحقاقه قبل نهاية السنة المالية</li>\r\n          </ul>\r\n          ويجب على مجلس الإدارة في الحالات رقم (3) و(4) و(5) إبلاغ من زالت عضويته خطياً بزوال عضويته وحقه بالاعتراض<br/>\r\n          كما يجوز للعضو بعد انتفاء سبب زوال العضوية أن يقدم طلباً إلى مجلس الإدارة لرد العضوية إليه، وعلى المجلس أن يبت في الطلب بقرارٍ مسبب ويبلغه إلى العضو\r\n        </p>\r\n        <br />\r\n        <h4></h4>\r\n        <p></p>\r\n        <br />\r\n        <h4></h4>\r\n        <p></p>\r\n        <br />\r\n        <h4></h4>\r\n        <p></p>\r\n        <br />\r\n        <h4></h4>\r\n        <p></p>\r\n        <br />\r\n      </div>\r\n    </>\r\n  )\r\n}","C:\\Users\\D2105\\Documents\\Projects\\Front-end\\React\\association\\src\\pages\\OurPrograms.js",[],[],"C:\\Users\\D2105\\Documents\\Projects\\Front-end\\React\\association\\src\\pages\\AwarenessLectureRequest.js",[],[],"C:\\Users\\D2105\\Documents\\Projects\\Front-end\\React\\association\\src\\pages\\Images.js",[],[],"C:\\Users\\D2105\\Documents\\Projects\\Front-end\\React\\association\\src\\pages\\Videos.js",[],[],"C:\\Users\\D2105\\Documents\\Projects\\Front-end\\React\\association\\src\\pages\\News.js",[],[],"C:\\Users\\D2105\\Documents\\Projects\\Front-end\\React\\association\\src\\pages\\AssociationCard.js",[],[],"C:\\Users\\D2105\\Documents\\Projects\\Front-end\\React\\association\\src\\pages\\SystemsRegulations.js",["348","349","350","351","352","353","354","355","356"],[],"import React, { useContext } from 'react'\r\nimport Texts from '../Texts';\r\nimport { Context } from '../Context';\r\nimport ConflictOfInterestPolicyPDF from '../files/ConflictOfInterestPolicy.pdf'\r\nimport WhistleblowingPolicyPDF from '../files/WhistleblowingPolicy.pdf'\r\nimport OrganizingRelationshipWithBeneficiariesPDF from '../files/OrganizingRelationshipWithBeneficiaries.pdf'\r\nimport FundraisingPolicyPDF from '../files/FundraisingPolicy.pdf'\r\nimport DataPrivacyPolicyPDF from '../files/DataPrivacyPolicy.pdf'\r\nimport DocumentRetentionPolicyPDF from '../files/DocumentRetentionPolicy.pdf'\r\nimport AntiTerroristFinancingPolicyPDF from '../files/AntiTerroristFinancingPolicy.pdf'\r\nimport VolunteerManagementMechanismPDF from '../files/VolunteerManagementMechanism.pdf'\r\nimport MechanismToVerifyTheBeneficiariesPDF from '../files/MechanismToVerifyTheBeneficiarysEligibility.pdf'\r\n\r\nexport default function SystemsRegulations() {\r\n\r\n  const { lang } = useContext(Context);\r\n  const texts = Texts[lang];\r\n\r\n  return (\r\n    <>\r\n      <div className='page-title'>\r\n        <h1>{texts.systemsRegulations}</h1>\r\n      </div>\r\n      <div className='content d-flex flex-column gap-4' style={{paddingInline: '300px'}}>\r\n        {texts.systemsRegulationsContent}\r\n        <a href={ConflictOfInterestPolicyPDF} className='decoration-none' download>\r\n          <div className='download'>\r\n            <h1>{texts.conflictPolicy}</h1>\r\n            <h1 class=\"fa-sharp fa-solid fa-download\"></h1>\r\n          </div>\r\n        </a>\r\n        <a href={WhistleblowingPolicyPDF} className='decoration-none' download>\r\n          <div className='download'>\r\n            <h1>{texts.whistleblowingPolicy}</h1>\r\n            <h1 class=\"fa-sharp fa-solid fa-download\"></h1>\r\n          </div>\r\n        </a>\r\n        <a href={OrganizingRelationshipWithBeneficiariesPDF} className='decoration-none' download>\r\n          <div className='download'>\r\n            <h1>{texts.organizingRelationshipWithBeneficiaries}</h1>\r\n            <h1 class=\"fa-sharp fa-solid fa-download\"></h1>\r\n          </div>\r\n        </a>\r\n        <a href={FundraisingPolicyPDF} className='decoration-none' download>\r\n          <div className='download'>\r\n            <h1>{texts.fundraisingPolicy}</h1>\r\n            <h1 class=\"fa-sharp fa-solid fa-download\"></h1>\r\n          </div>\r\n        </a>\r\n        <a href={DataPrivacyPolicyPDF} className='decoration-none' download>\r\n          <div className='download'>\r\n            <h1>{texts.dataPrivacyPolicy}</h1>\r\n            <h1 class=\"fa-sharp fa-solid fa-download\"></h1>\r\n          </div>\r\n        </a>\r\n        <a href={DocumentRetentionPolicyPDF} className='decoration-none' download>\r\n          <div className='download'>\r\n            <h1>{texts.documentRetentionPolicy}</h1>\r\n            <h1 class=\"fa-sharp fa-solid fa-download\"></h1>\r\n          </div>\r\n        </a>\r\n        <a href={AntiTerroristFinancingPolicyPDF} className='decoration-none' download>\r\n          <div className='download'>\r\n            <h1>{texts.antiTerroristFinancingPolicy}</h1>\r\n            <h1 class=\"fa-sharp fa-solid fa-download\"></h1>\r\n          </div>\r\n        </a>\r\n        <a href={VolunteerManagementMechanismPDF} className='decoration-none' download>\r\n          <div className='download'>\r\n            <h1>{texts.volunteerManagementMechanism}</h1>\r\n            <h1 class=\"fa-sharp fa-solid fa-download\"></h1>\r\n          </div>\r\n        </a>\r\n        <a href={MechanismToVerifyTheBeneficiariesPDF} className='decoration-none' download>\r\n          <div className='download'>\r\n            <h1>{texts.mechanismToVerifyTheBeneficiaries}</h1>\r\n            <h1 class=\"fa-sharp fa-solid fa-download\"></h1>\r\n          </div>\r\n        </a>\r\n      </div>\r\n    </>\r\n  )\r\n}","C:\\Users\\D2105\\Documents\\Projects\\Front-end\\React\\association\\src\\pages\\Subscripers.js",["357","358","359","360","361","362","363","364","365","366","367","368","369","370","371","372","373"],[],"import React, { useEffect, useState } from 'react'\r\nimport { useNavigate } from 'react-router-dom'\r\n\r\nexport default function Subscripers() {\r\n\r\n    const navigate = useNavigate();\r\n    const [password, setPassword] = useState('');\r\n    const [individualData, setIndividualData] = useState([]);\r\n    const [facilityData, setFacilityData] = useState([]);\r\n    const [individualDetails, setIndividualDetails] = useState(0);\r\n    const [facilityDetails, setFacilityDetails] = useState(0);\r\n\r\n    async function send() {\r\n        if (password == '3VwWKzATJ45M'){\r\n            let individualResult = await fetch(\"https://vahpa.org.sa/server/api/individual-view\");\r\n            individualResult = await individualResult.json();\r\n            setIndividualData(individualResult)\r\n\r\n            let facilityResult = await fetch(\"https://vahpa.org.sa/server/api/facility-view\");\r\n            facilityResult = await facilityResult.json();\r\n            setFacilityData(facilityResult)\r\n        }\r\n        else{\r\n            alert('كلمة المرور خاطئة')\r\n        }\r\n    }\r\n\r\n    return (\r\n        <div>\r\n            <div className='page-title'>\r\n                <h1>عرض جميع المشتركين</h1>\r\n            </div>\r\n\r\n            <div className='content'>\r\n\r\n                <div className='row justify-content-center text-end'>\r\n                    <div className='col-md-6'>\r\n                        {facilityData.length == 0 && individualData.length == 0 ? (\r\n                            <div className='card shadow-sm'>\r\n                                <div className='card-header'>\r\n                                    <h4 className='text-black'>ادخل كلمة السر لعرض المشتركين</h4>\r\n                                </div>\r\n                                <div className='card-body'>\r\n                                    <input className='form-control my-4' placeholder='كلمة المرور' onChange={e => setPassword(e.target.value)} />\r\n                                    <button className='btn btn bg-dark text-white float-start' onClick={send} defaultValue={password} >إرسال</button>\r\n                                </div>\r\n                            </div>\r\n                        )\r\n                            : (\r\n                                <>\r\n                                    <div className='card shadow-sm mb-5'>\r\n                                        <div className='card-header'>\r\n                                            <h4 className='text-black'>عضويات الأفراد</h4>\r\n                                        </div>\r\n                                        <div className='card-body'>\r\n\r\n                                            {individualDetails != 0\r\n                                                ? (\r\n                                                    <div>\r\n                                                        {individualData.filter(data => data.id == individualDetails).map(data => (\r\n                                                            <div key={data.id}>\r\n                                                                <p>رقم:</p>\r\n                                                                <p className='text-center'>{data.id}</p>\r\n                                                                <p>الاسم:</p>\r\n                                                                <p className='text-center'>{data.name}</p>\r\n                                                                <p>العمر:</p>\r\n                                                                <p className='text-center'>{data.age}</p>\r\n                                                                <p>الجنسية:</p>\r\n                                                                <p className='text-center'>{data.nationality}</p>\r\n                                                                <p>رقم الهوية:</p>\r\n                                                                <p className='text-center'>{data.identityNo}</p>\r\n                                                                <p>مصدر الهوية:</p>\r\n                                                                <p className='text-center'>{data.identitySource}</p>\r\n                                                                <p>تاريخ اصدار الهوية:</p>\r\n                                                                <p className='text-center'>{data.identityDate}</p>\r\n                                                                <p>مكان الميلاد:</p>\r\n                                                                <p className='text-center'>{data.birthPlace}</p>\r\n                                                                <p>تاريخ الميلاد:</p>\r\n                                                                <p className='text-center'>{data.birthDate}</p>\r\n                                                                <p>مكان الاقامة:</p>\r\n                                                                <p className='text-center'>{data.residence}</p>\r\n                                                                <p>المهنة:</p>\r\n                                                                <p className='text-center'>{data.occupation}</p>\r\n                                                                <p>رقم الجوال:</p>\r\n                                                                <p className='text-center'>{data.phone}</p>\r\n                                                                <p>رقم الهاتف:</p>\r\n                                                                <p className='text-center'>{data.tel}</p>\r\n                                                                <p>البريد الإلكتروني:</p>\r\n                                                                <p className='text-center'>{data.email}</p>\r\n                                                                <p>صندوق البريد:</p>\r\n                                                                <p className='text-center'>{data.Postalbox}</p>\r\n                                                                <p>الرمز البريدي:</p>\r\n                                                                <p className='text-center'>{data.Postalcode}</p>\r\n                                                                <p>المؤهل العلمي:</p>\r\n                                                                <p className='text-center'>{data.qualification}</p>\r\n                                                                <p>التخصص:</p>\r\n                                                                <p className='text-center'>{data.specialization}</p>\r\n                                                                <p>نوع العضوية:</p>\r\n                                                                <p className='text-center'>{data.role}</p>\r\n                                                                <p>وذلك لكوني:</p>\r\n                                                                <p className='text-center'>{data.reason}</p>\r\n\r\n                                                                <a href={`https://vahpa.org.sa/server/${data.endorsement}`} className='decoration-none' download target='_blank'>\r\n                                                                    <div className='download-approval mt-5'>\r\n                                                                        <li className=\"fa-sharp fa-solid fa-download\"></li>\r\n                                                                        <label>تحميل إقرار الجمعية</label>\r\n                                                                    </div>\r\n                                                                </a>\r\n                                                                <a href={`https://vahpa.org.sa/server/${data.identityImg}`} className='decoration-none' download target='_blank'>\r\n                                                                    <div className='download-approval'>\r\n                                                                        <li className=\"fa-sharp fa-solid fa-download\"></li>\r\n                                                                        <label>تحميل صورة الهوية</label>\r\n                                                                    </div>\r\n                                                                </a>\r\n                                                                <a href={`https://vahpa.org.sa/server/${data.nationalAddressImg}`} className='decoration-none' download target='_blank'>\r\n                                                                    <div className='download-approval'>\r\n                                                                        <li className=\"fa-sharp fa-solid fa-download\"></li>\r\n                                                                        <label>تحميل صورة العنوان الوطني</label>\r\n                                                                    </div>\r\n                                                                </a>\r\n                                                                <a href={`https://vahpa.org.sa/server/${data.transferImg}`} className='decoration-none' download target='_blank'>\r\n                                                                    <div className='download-approval'>\r\n                                                                        <li className=\"fa-sharp fa-solid fa-download\"></li>\r\n                                                                        <label>تحميل صورة حوالة سداد الرسوم</label>\r\n                                                                    </div>\r\n                                                                </a>\r\n                                                            </div>\r\n                                                        ))}\r\n                                                        <button onClick={() => setIndividualDetails(0)} className='btn btn bg-dark text-white my-5'>رجوع</button>\r\n                                                    </div>\r\n\r\n                                                )\r\n                                                : (\r\n\r\n                                                    <div className='table-responsive'>\r\n                                                        <table className='table table-bordered table-striped'>\r\n                                                            <thead>\r\n                                                                <tr>\r\n                                                                    <th>رقم</th>\r\n                                                                    <th>الإسم</th>\r\n                                                                    <th>ضبط</th>\r\n                                                                </tr>\r\n                                                            </thead>\r\n                                                            <tbody>\r\n                                                                {individualData.map(data => (\r\n                                                                    <tr key={data.id}>\r\n                                                                        <td>{data.id}</td>\r\n                                                                        <td>{data.name}</td>\r\n                                                                        <td>\r\n                                                                            <button className='btn btn-sm bg-dark text-white' onClick={() => setIndividualDetails(data.id)}>عرض</button>\r\n                                                                        </td>\r\n                                                                    </tr>\r\n                                                                ))}\r\n                                                            </tbody>\r\n                                                        </table>\r\n                                                    </div>\r\n                                                )}\r\n\r\n                                        </div>\r\n                                    </div>\r\n                                    <div className='card shadow-sm'>\r\n                                        <div className='card-header'>\r\n                                            <h4 className='text-black'>عضويات الجهات</h4>\r\n                                        </div>\r\n                                        <div className='card-body'>\r\n                                            \r\n                                            {facilityDetails != 0 \r\n                                            ? (\r\n\r\n                                                <div>\r\n                                                    {facilityData.filter(data => data.id == facilityDetails).map(data => (\r\n                                                        <div key={data.id}>\r\n                                                            <p>رقم:</p>\r\n                                                            <p className='text-center'>{data.id}</p>\r\n\r\n                                                            <p>إسم الجهة:</p>\r\n                                                            <p className='text-center'>{data.facilityName}</p>                                                                                                                        \r\n                                                            <p>الجنسية / المقر:</p>\r\n                                                            <p className='text-center'>{data.facilityPlace}</p>                                                                                                                        \r\n                                                            <p>رقم التسجيل / الترخيص:</p>\r\n                                                            <p className='text-center'>{data.facilityRegisterNo}</p>                                                                                                                        \r\n                                                            <p>تاريخ إصدار الجهة:</p>\r\n                                                            <p className='text-center'>{data.facilityIssueDate}</p>                                                                                                                        \r\n                                                            <p>رقم جوال الجهة:</p>\r\n                                                            <p className='text-center'>{data.facilityPhone}</p>                                                                                                                        \r\n                                                            <p>رقم هاتف الجهة:</p>\r\n                                                            <p className='text-center'>{data.facilityTel}</p>                                                                                                                        \r\n                                                            <p>البريد الإلكتروني للجهة:</p>\r\n                                                            <p className='text-center'>{data.facilityEmail}</p>                                                                                                                        \r\n                                                            <p>صندوق بريد الجهة:</p>\r\n                                                            <p className='text-center'>{data.facilityPostalBox}</p>                                                                                                                        \r\n                                                            <p>الرمز البريدي للجهة:</p>\r\n                                                            <p className='text-center'>{data.facilityPostalCode}</p>                                                                                                                        \r\n                                                            <p>نوع عضوية الجهة:</p>\r\n                                                            <p className='text-center'>{data.facilityRole}</p>                                                                                                                        \r\n                                                            <p>الهدف من عضوية الجمعية:</p>\r\n                                                            <p className='text-center'>{data.facilityGoal}</p>      \r\n                                                            <p>الاسم:</p>\r\n                                                            <p className='text-center'>{data.name}</p>\r\n                                                            <p>العمر:</p>\r\n                                                            <p className='text-center'>{data.age}</p>\r\n                                                            <p>الجنسية:</p>\r\n                                                            <p className='text-center'>{data.nationality}</p>\r\n                                                            <p>رقم الهوية:</p>\r\n                                                            <p className='text-center'>{data.identityNo}</p>\r\n                                                            <p>مصدر الهوية:</p>\r\n                                                            <p className='text-center'>{data.identitySource}</p>\r\n                                                            <p>تاريخ اصدار الهوية:</p>\r\n                                                            <p className='text-center'>{data.identityDate}</p>\r\n                                                            <p>مكان الميلاد:</p>\r\n                                                            <p className='text-center'>{data.birthPlace}</p>\r\n                                                            <p>تاريخ الميلاد:</p>\r\n                                                            <p className='text-center'>{data.birthDate}</p>\r\n                                                            <p>مكان الاقامة:</p>\r\n                                                            <p className='text-center'>{data.residence}</p>\r\n                                                            <p>المهنة:</p>\r\n                                                            <p className='text-center'>{data.occupation}</p>\r\n                                                            <p>رقم الجوال:</p>\r\n                                                            <p className='text-center'>{data.phone}</p>\r\n                                                            <p>رقم الهاتف:</p>\r\n                                                            <p className='text-center'>{data.tel}</p>\r\n                                                            <p>البريد الإلكتروني:</p>\r\n                                                            <p className='text-center'>{data.email}</p>\r\n                                                            <p>صندوق البريد:</p>\r\n                                                            <p className='text-center'>{data.Postalbox}</p>\r\n                                                            <p>الرمز البريدي:</p>\r\n                                                            <p className='text-center'>{data.Postalcode}</p>\r\n                                                            <p>المؤهل العلمي:</p>\r\n                                                            <p className='text-center'>{data.qualification}</p>\r\n                                                            <p>التخصص:</p>\r\n                                                            <p className='text-center'>{data.specialization}</p>\r\n                                                            <p>نوع العضوية:</p>\r\n                                                            <p className='text-center'>{data.role}</p>\r\n                                                            <p>وذلك لكوني:</p>\r\n                                                            <p className='text-center'>{data.reason}</p>\r\n\r\n                                                            <a href={`https://vahpa.org.sa/server/${data.endorsement}`} className='decoration-none' download target='_blank'>\r\n                                                                <div className='download-approval mt-5'>\r\n                                                                    <li className=\"fa-sharp fa-solid fa-download\"></li>\r\n                                                                    <label>تحميل إقرار الجمعية</label>\r\n                                                                </div>\r\n                                                            </a>\r\n                                                            <a href={`https://vahpa.org.sa/server/${data.identityImg}`} className='decoration-none' download target='_blank'>\r\n                                                                <div className='download-approval'>\r\n                                                                    <li className=\"fa-sharp fa-solid fa-download\"></li>\r\n                                                                    <label>تحميل صورة الهوية</label>\r\n                                                                </div>\r\n                                                            </a>\r\n                                                            <a href={`https://vahpa.org.sa/server/${data.registerImg}`} className='decoration-none' download target='_blank'>\r\n                                                                <div className='download-approval'>\r\n                                                                    <li className=\"fa-sharp fa-solid fa-download\"></li>\r\n                                                                    <label>تحميل صورة السجل</label>\r\n                                                                </div>\r\n                                                            </a>\r\n                                                            <a href={`https://vahpa.org.sa/server/${data.nationalAddressImg}`} className='decoration-none' download target='_blank'>\r\n                                                                <div className='download-approval'>\r\n                                                                    <li className=\"fa-sharp fa-solid fa-download\"></li>\r\n                                                                    <label>تحميل صورة العنوان الوطني</label>\r\n                                                                </div>\r\n                                                            </a>\r\n                                                            <a href={`https://vahpa.org.sa/server/${data.transferImg}`} className='decoration-none' download target='_blank'>\r\n                                                                <div className='download-approval'>\r\n                                                                    <li className=\"fa-sharp fa-solid fa-download\"></li>\r\n                                                                    <label>تحميل صورة حوالة سداد الرسوم</label>\r\n                                                                </div>\r\n                                                            </a>\r\n                                                        </div>\r\n                                                    ))}\r\n                                                    <button onClick={() => setFacilityDetails(0)} className='btn btn bg-dark text-white my-5'>رجوع</button>\r\n                                                </div>\r\n\r\n                                            )\r\n                                            : (\r\n\r\n                                                <div className='table-responsive'>\r\n                                                    <table className='table table-bordered table-striped'>\r\n                                                        <thead>\r\n                                                            <tr>\r\n                                                                <th>رقم</th>\r\n                                                                <th>الإسم</th>\r\n                                                                <th>ضبط</th>\r\n                                                            </tr>\r\n                                                        </thead>\r\n                                                        <tbody>\r\n                                                            {facilityData.map(data => (\r\n                                                                <tr key={data.id}>\r\n                                                                    <td>{data.id}</td>\r\n                                                                    <td>{data.name}</td>\r\n                                                                    <td>\r\n                                                                        <button className='btn btn-sm bg-dark text-white' onClick={() => setFacilityDetails(data.id)}>عرض</button>\r\n                                                                    </td>\r\n                                                                </tr>\r\n                                                            ))}\r\n                                                        </tbody>\r\n                                                    </table>\r\n                                                </div>\r\n                                            )}\r\n\r\n\r\n                                        </div>\r\n                                    </div>\r\n                                </>\r\n                            )}\r\n                    </div>\r\n                </div>\r\n\r\n                <div className='row justify-content-center text-end'>\r\n                    <div className='col-md-6'>\r\n                        <button onClick={() => navigate('/association-register')} className='btn btn bg-dark text-white my-5'>رجوع</button>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    )\r\n}","C:\\Users\\D2105\\Documents\\Projects\\Front-end\\React\\association\\src\\pages\\Reports.js",[],[],"C:\\Users\\D2105\\Documents\\Projects\\Front-end\\React\\association\\src\\components\\Footer.js",["374","375","376","377","378","379"],[],"import React, { useContext } from 'react'\r\nimport Texts from '../Texts';\r\nimport {Context} from '../Context';\r\n\r\nexport default function Footer() {\r\n    \r\n    const {lang} = useContext(Context);\r\n    const texts = Texts[lang];\r\n\r\n  return (\r\n    <div className='Footer'>\r\n        <p>{texts.identity}</p>\r\n        <div>\r\n            <p>{texts.callUs}:</p>\r\n            <a href='mailto: info@vahpa.org.sa ' target='_blank'>\r\n                <i className=\"fa-solid fa-envelope\"></i>\r\n            </a>\r\n            <a href='https://twitter.com/VAHPA_SA' target='_blank'>\r\n                <i className=\"fa-brands fa-twitter\"></i>\r\n            </a>\r\n            <a href='https://www.linkedin.com/in/%D8%AC%D9%85%D8%B9%D9%8A%D8%A9-%D8%A7%D9%84%D9%88%D9%82%D8%A7%D9%8A%D8%A9-%D9%85%D9%86-%D8%A7%D9%84%D8%B9%D9%86%D9%81-%D9%88%D8%A7%D9%84%D8%A5%D9%8A%D8%B0%D8%A7%D8%A1-%D9%88%D8%A7%D9%84%D8%AA%D8%B4%D8%B1%D8%AF-b04072255/' target='_blank'>\r\n                <i className=\"fa-brands fa-linkedin\"></i>\r\n            </a>\r\n            <a href='https://wa.me/+966576344747?text=Hi' target='_blank'>\r\n                <i className=\"fa-brands fa-whatsapp\"></i>\r\n            </a>\r\n            <a href='https://www.instagram.com/vahpa_sa/ ' target='_blank'>\r\n                <i className=\"fa-brands fa-instagram\"></i>\r\n            </a>\r\n            <a href='https://t.me' target='_blank'>\r\n                <i className=\"fa-brands fa-telegram\"></i>\r\n            </a>\r\n            <a href='tel: +966576344747'>\r\n                <i className=\"fa-solid fa-phone\"></i>\r\n            </a>\r\n        </div>\r\n    </div>\r\n  )\r\n}","C:\\Users\\D2105\\Documents\\Projects\\Front-end\\React\\association\\src\\components\\Header.js",["380","381","382"],[],"import React, { useContext } from 'react'\r\nimport logo from '../images/logo.png';\r\nimport title from '../images/title.png';\r\nimport Texts from '../Texts';\r\nimport { Context } from '../Context';\r\nimport { useNavigate } from 'react-router-dom';\r\n\r\nexport default function Header(changeLang) {\r\n\r\n  const { lang, setLang } = useContext(Context);\r\n  const texts = Texts[lang];\r\n  const navigate = useNavigate();\r\n\r\n  function changeLang() {\r\n    lang == 'ar'\r\n      ? setLang('en')\r\n      : setLang('ar')\r\n  }\r\n\r\n  function links(page){\r\n    window.scrollTo(0, 0);\r\n    navigate(page)\r\n  }\r\n\r\n  return (\r\n    <div className='Header'>\r\n      <div className='banner'>\r\n        <img src={logo} className='logo-img' alt='logo' />\r\n        <img src={title} className='title-img' alt='title' />\r\n      </div>\r\n      <div className='Navbar'>\r\n        <div>\r\n          <button onClick={()=>{links('/')}}>{texts.mainPage}</button>\r\n        </div>\r\n        <div>\r\n          <button>{texts.about}<i className=\"fa-sharp fa-solid fa-caret-down\"></i></button>\r\n          <ul>\r\n            <li onClick={()=>{links('/about')}}>{texts.aboutAssociation}</li>\r\n            <li onClick={()=>{links('/chairmanword')}}>{texts.chairmanWord}</li>\r\n            <li onClick={()=>{links('/general-association')}}>{texts.generalAssociation}</li>\r\n            <li onClick={()=>{links('/organizational-structure')}}>{texts.organizationalStructure}</li>\r\n            <li onClick={()=>{links('/board-directors')}}>{texts.boardDirectors}</li>\r\n            <li onClick={()=>{links('/executive-committee')}}>{texts.executiveCommittee}</li>\r\n            <li onClick={()=>{links('/investment-committe')}}>{texts.investmentCommitte}</li>\r\n            <li onClick={()=>{links('/planing-development-committe')}}>{texts.planingDevelopmentCommitte}</li>\r\n\r\n            <li onClick={()=>{links('/policy-governance-review-committee')}}>{texts.policyGovernanceReviewCommittee}</li>\r\n            <li onClick={()=>{links('/internal-audit-review-committee')}}>{texts.internalAuditReviewCommittee}</li>\r\n          </ul>\r\n        </div>\r\n        <div>\r\n          <button>{texts.services} <i className=\"fa-sharp fa-solid fa-caret-down\"></i></button>\r\n          <ul>\r\n            <a className='decoration-none text-white' href='https://nvg.gov.sa' target='_blank'>\r\n              <li>{texts.voluntare}</li>\r\n            </a>\r\n            <li onClick={()=>{links('/awareness-corner-request')}}>{texts.awarenessCornerRequest}</li>\r\n            <li onClick={()=>{links('/awareness-lecture-request')}}>{texts.awarenessLectureRequest}</li>\r\n          </ul>\r\n        </div>\r\n        <div>\r\n          <button>{texts.membership} <i className=\"fa-sharp fa-solid fa-caret-down\"></i></button>\r\n          <ul>\r\n            <li onClick={()=>{links('/about-membership')}}>{texts.aboutMembership}</li>\r\n            <li onClick={()=>{links('/association-register')}}>{texts.associationRegister}</li>\r\n            <li onClick={()=>{links('/association-card')}}>{texts.associationCard}</li>\r\n          </ul>\r\n        </div>\r\n        <div>\r\n          <button onClick={()=>{links('/our-programs')}}>{texts.ourPrograms}</button>\r\n        </div>\r\n        <div>\r\n          <button onClick={()=>{links('/news')}}>{texts.news}</button>\r\n        </div>\r\n        <div>\r\n          <button>{texts.library} <i className=\"fa-sharp fa-solid fa-caret-down\"></i></button>\r\n          <ul>\r\n            <li onClick={()=>{links('/images')}}>{texts.images}</li>\r\n            <li onClick={()=>{links('/videos')}}>{texts.videos}</li>\r\n            <li onClick={()=>{links('/reports')}}>{texts.reports}</li>\r\n            <li onClick={()=>{links('/systems-regulations')}}>{texts.systemsRegulations}</li>\r\n          </ul>\r\n        </div>\r\n        <div>\r\n          <button onClick={()=>{links('/call-us')}}>{texts.callUs}</button>\r\n        </div>\r\n        <div className='donate-div'>\r\n          <button onClick={()=>{links('/donate')}}>{texts.donate}</button>\r\n        </div>\r\n        <div>\r\n          <button onClick={changeLang}>{texts.lang}</button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  )\r\n}","C:\\Users\\D2105\\Documents\\Projects\\Front-end\\React\\association\\src\\pages\\Donate.js",[],[],"C:\\Users\\D2105\\Documents\\Projects\\Front-end\\React\\association\\src\\pages\\CallUs.js",[],[],{"ruleId":"383","severity":1,"message":"384","line":1,"column":27,"nodeType":"385","messageId":"386","endLine":1,"endColumn":36},{"ruleId":"383","severity":1,"message":"387","line":39,"column":11,"nodeType":"385","messageId":"386","endLine":39,"endColumn":16},{"ruleId":"388","severity":1,"message":"389","line":43,"c
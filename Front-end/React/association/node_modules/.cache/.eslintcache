errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"71"},"C:\\Users\\D2105\\Documents\\Projects\\Front-end\\React\\association\\src\\index.js",[],[],[],"C:\\Users\\D2105\\Documents\\Projects\\Front-end\\React\\association\\src\\Context.js",["180"],[],"import React, { useState, useEffect } from 'react'\r\n\r\nexport const Context = React.createContext({});\r\n\r\nexport default function ContextProvider({ children }) {\r\n\r\n  const [ lang, setLang ] = useState(\"ar\");\r\n\r\n//   useEffect(() => {\r\n//     const storedLang = JSON.parse(localStorage.getItem(\"lang\"))\r\n//     storedLang && setLang(storedLang)\r\n//   }, []);\r\n\r\n//   useEffect(() => {\r\n//     localStorage.setItem(\"lang\", JSON.stringify(lang))\r\n//   }, [lang]);\r\n\r\n  return (\r\n    <Context.Provider value={{ lang, setLang }}>\r\n      {children}\r\n    </Context.Provider>\r\n  )\r\n}","C:\\Users\\D2105\\Documents\\Projects\\Front-end\\React\\association\\src\\App.js",[],[],"C:\\Users\\D2105\\Documents\\Projects\\Front-end\\React\\association\\src\\layouts\\Guest.js",["181","182","183","184","185","186","187","188","189","190","191","192","193","194","195","196","197","198","199","200","201","202","203","204","205","206","207","208"],[],"import React, { useContext, useEffect, useRef } from 'react'\r\nimport { Context } from '../Context';\r\nimport Texts from '../Texts';\r\n//components\r\nimport Header from '../components/Header';\r\nimport Footer from '../components/Footer';\r\n//pages\r\nimport Main from '../pages/Main';\r\nimport About from '../pages/About'; \r\nimport GeneralAssociation from '../pages/GeneralAssociation'\r\nimport ChairmanWord from '../pages/ChairmanWord'\r\nimport OrganizationalStructure from '../pages/OrganizationalStructure'\r\nimport BoardDirectors from '../pages/BoardDirectors'\r\nimport ExecutiveCommittee from '../pages/ExecutiveCommittee'\r\nimport InvestmentCommitte from '../pages/InvestmentCommitte'\r\nimport PlaningDevelopmentCommitte from '../pages/PlaningDevelopmentCommitte'\r\nimport PolicyGovernanceReviewCommittee from '../pages/PolicyGovernanceReviewCommittee'\r\nimport InternalAuditReviewCommittee from '../pages/InternalAuditReviewCommittee'\r\nimport Voluntare from '../pages/Voluntare'\r\nimport AwarenessCornerRequest from '../pages/AwarenessCornerRequest'\r\nimport AwarenessLectureRequest from '../pages/AwarenessLectureRequest'\r\nimport AboutMembership from '../pages/AboutMembership'\r\nimport AssociationRegister from '../pages/AssociationRegister'\r\nimport AssociationCard from '../pages/AssociationCard'\r\nimport OurPrograms from '../pages/OurPrograms'\r\nimport News from '../pages/News'\r\nimport Images from '../pages/Images'\r\nimport Videos from '../pages/Videos'\r\nimport Reports from '../pages/Reports'\r\nimport SystemsRegulations from '../pages/SystemsRegulations'\r\nimport CallUs from '../pages/CallUs'\r\nimport Donate from '../pages/Donate'\r\nimport Subscripers from '../pages/Subscripers';\r\n\r\nexport default function Guest(props) {\r\n\r\n    let {page} = props;\r\n    const { lang } = useContext(Context);\r\n    const texts = Texts[lang];\r\n    const container = useRef();\r\n\r\n    useEffect(() => {\r\n        lang == 'ar'\r\n        ? container.current.style.direction = 'rtl'\r\n        : container.current.style.direction = 'ltr'\r\n    }, [lang])\r\n\r\n    return (\r\n        <div ref={container} className='Container'>\r\n            <Header />\r\n            {page == '' && <Main />}\r\n            {page == 'about' && <About />}\r\n            {page == 'chairmanword' && <ChairmanWord />}\r\n            {page == 'general-association' && <GeneralAssociation />}\r\n            {page == 'organizational-structure' && <OrganizationalStructure />}\r\n            {page == 'board-directors' && <BoardDirectors />}\r\n            {page == 'executive-committee' && <ExecutiveCommittee />}\r\n            {page == 'investment-committe' && <InvestmentCommitte />}\r\n            {page == 'planing-development-committe' && <PlaningDevelopmentCommitte />}\r\n            {page == 'policy-governance-review-committee' && <PolicyGovernanceReviewCommittee />}\r\n            {page == 'internal-audit-review-committee' && <InternalAuditReviewCommittee />}\r\n            {page == 'voluntare' && <Voluntare />}\r\n            {page == 'awareness-corner-request' && <AwarenessCornerRequest />}\r\n            {page == 'awareness-lecture-request' && <AwarenessLectureRequest />}\r\n            {page == 'about-membership' && <AboutMembership />}\r\n            {page == 'association-register' && <AssociationRegister />}\r\n            {page == 'association-card' && <AssociationCard />}\r\n            {page == 'our-programs' && <OurPrograms />}\r\n            {page == 'news' && <News />}\r\n            {page == 'images' && <Images />}\r\n            {page == 'videos' && <Videos />}\r\n            {page == 'reports' && <Reports />}\r\n            {page == 'systems-regulations' && <SystemsRegulations />}\r\n            {page == 'call-us' && <CallUs />}\r\n            {page == 'donate' && <Donate />}\r\n            {page == 'subscribers' && <Subscripers />}\r\n            <Footer />\r\n        </div>\r\n    )\r\n}","C:\\Users\\D2105\\Documents\\Projects\\Front-end\\React\\association\\src\\Texts.js",[],[],"C:\\Users\\D2105\\Documents\\Projects\\Front-end\\React\\association\\src\\pages\\About.js",[],[],"C:\\Users\\D2105\\Documents\\Projects\\Front-end\\React\\association\\src\\pages\\OrganizationalStructure.js",["209"],[],"import React, { useContext } from 'react'\r\nimport Texts from '../Texts';\r\nimport { Context } from '../Context';\r\nimport image from '../images/organizationalstructure.PNG'\r\n\r\nexport default function OrganizationalStructure() {\r\n\r\n  const { lang } = useContext(Context);\r\n  const texts = Texts[lang];\r\n\r\n  return (\r\n    <>\r\n      <div className='page-title'>\r\n        <h1>{texts.organizationalStructure}</h1>\r\n      </div>\r\n      <div className='content'>\r\n        {/* {texts.organizationalStructureContent} */}\r\n        <img src={image} alt='image' style={{width: '100%'}}/>\r\n      </div>\r\n    </>\r\n  )\r\n}","C:\\Users\\D2105\\Documents\\Projects\\Front-end\\React\\association\\src\\pages\\PlaningDevelopmentCommitte.js",[],[],"C:\\Users\\D2105\\Documents\\Projects\\Front-end\\React\\association\\src\\pages\\Main.js",["210","211","212","213","214","215","216","217"],[],"import React, { useContext, useEffect, useRef, useState } from 'react'\r\nimport { Context } from '../Context';\r\nimport Texts from '../Texts';\r\nimport logoWhite from '../images/logoWhite.png';\r\nimport panner1 from '../images/panner1.jpg'\r\nimport panner2 from '../images/panner2.jpg'\r\n\r\nexport default function Main() {\r\n\r\n  const { lang } = useContext(Context);\r\n  const texts = Texts[lang];\r\n  const [activeImg, setActiveImg] = useState('img1');\r\n\r\n  useEffect(() => {\r\n    const script = document.createElement('script');\r\n\r\n    script.src = \"https://platform.twitter.com/widgets.js\";\r\n    script.async = true;\r\n\r\n    document.body.appendChild(script);\r\n  }, []);\r\n\r\n  useEffect(()=>{\r\n    img1();\r\n  },[])\r\n\r\n  function img1(){\r\n    setActiveImg('img1')\r\n    setTimeout(img2, 8000);\r\n  }\r\n  function img2(){\r\n    setActiveImg('img2')\r\n    setTimeout(img1, 8000);\r\n  }\r\n\r\n  return (\r\n    <div className='body'>\r\n      <img className='background-img' src={panner2} alt='panner' />\r\n      <div className=\"Slideshow-container\">\r\n        <div className={`mySlides Fade ${activeImg == \"img1\" && 'ShowSlide'}`}>\r\n          <img src={panner1} className='slide-img' />\r\n        </div>\r\n        <div className={`mySlides Fade ${activeImg == \"img2\" && 'ShowSlide'}`}>\r\n          <img src={panner2} className='slide-img' />\r\n        </div>\r\n      </div>\r\n      <div className='dot-container'>\r\n        <span className={`dot ${activeImg == \"img1\" && 'activeDot'}`} onClick={() => { setActiveImg('img1') }}></span>\r\n        <span className={`dot ${activeImg == \"img2\" && 'activeDot'}`} onClick={() => { setActiveImg('img2') }}></span>\r\n      </div>\r\n      <div className='news-container'>\r\n        <h2>{texts.latestNews}</h2>\r\n        <div className='post-container'>\r\n          <div className='post'>\r\n            <img src={logoWhite} alt='img' />\r\n            <div>\r\n              <h1>23</h1>\r\n              <p>2022 Oct</p>\r\n            </div>\r\n            <section></section>\r\n            <p>{texts.post}</p>\r\n          </div>\r\n          <div className='post'>\r\n            <img src={logoWhite} alt='img' />\r\n            <div>\r\n              <h1>23</h1>\r\n              <p>2022 Oct</p>\r\n            </div>\r\n            <section></section>\r\n            <p>{texts.post}</p>\r\n          </div>\r\n          <div className='post'>\r\n            <img src={logoWhite} alt='img' />\r\n            <div>\r\n              <h1>23</h1>\r\n              <p>2022 Oct</p>\r\n            </div>\r\n            <section></section>\r\n            <p>{texts.post}</p>\r\n          </div>\r\n          <div className='post'>\r\n            <img src={logoWhite} alt='img' />\r\n            <div>\r\n              <h1>23</h1>\r\n              <p>2022 Oct</p>\r\n            </div>\r\n            <section></section>\r\n            <p>{texts.post}</p>\r\n          </div>\r\n          <div className='post'>\r\n            <img src={logoWhite} alt='img' />\r\n            <div>\r\n              <h1>23</h1>\r\n              <p>2022 Oct</p>\r\n            </div>\r\n            <section></section>\r\n            <p>{texts.post}</p>\r\n          </div>\r\n          <div className='post'>\r\n            <img src={logoWhite} alt='img' />\r\n            <div>\r\n              <h1>23</h1>\r\n              <p>2022 Oct</p>\r\n            </div>\r\n            <section></sectio